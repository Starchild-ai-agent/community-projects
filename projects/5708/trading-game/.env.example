# ---- WalletConnect (Reown) ----
# Get yours from https://cloud.reown.com (formerly cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# ---- Chain ----
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_CHAIN=sepolia
NEXT_PUBLIC_BLOCK_EXPLORER=https://sepolia.etherscan.io

# ---- Contract ----
# Address of the deployed TradingGame contract (auto-set by deploy script)
NEXT_PUBLIC_TRADING_GAME_ADDRESS=
# ERC20 token used for margin (USDT or platform token)
NEXT_PUBLIC_MARGIN_TOKEN_ADDRESS=
NEXT_PUBLIC_MARGIN_TOKEN_DECIMALS=18
NEXT_PUBLIC_MARGIN_TOKEN_SYMBOL=USDT

# ---- Oracle signer (backend only — NEVER expose to frontend) ----
# Private key that signs close prices. Its address must match the contract's oracleSigner.
ORACLE_PRIVATE_KEY=
# Address derived from ORACLE_PRIVATE_KEY (for sanity checks)
ORACLE_SIGNER_ADDRESS=

# ---- Deployer (Hardhat only) ----
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
MARGIN_TOKEN_ADDRESS=
ORACLE_SIGNER_ADDRESS=
FEE_RECIPIENT_ADDRESS=

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Price API ----
# Provider: "binance" | "coingecko" | "mock"
PRICE_PROVIDER=binance
COINGECKO_API_KEY=

# ---- Admin ----
# Comma-separated list of admin wallet addresses
ADMIN_WALLETS=

# ---- Rate limiting (per IP per minute) ----
RATE_LIMIT_OPEN=10
RATE_LIMIT_CLOSE=20

# ---- Cron ----
# Bearer token for /api/cron/* routes. Vercel cron sends this in Authorization.
CRON_SECRET=
NEXT_PUBLIC_CRON_SECRET=
