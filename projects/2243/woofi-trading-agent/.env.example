# WOOFi API Key (ed25519 public key, with ed25519: prefix)
# Get from: https://pro.woofi.com/en/portfolio/api-key
WOOFI_API_KEY=ed25519:your-public-key-here

# WOOFi API Secret (ed25519 private key, with ed25519: prefix)
WOOFI_API_SECRET=ed25519:your-private-key-here

# WOOFi/Orderly Account ID (hex address starting with 0x)
# Found on the same API key page
WOOFI_ACCOUNT_ID=0xyour-account-id-here
