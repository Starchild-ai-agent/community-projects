# QuoteSim — all core features work with NO keys (Hyperliquid info API,
# Pyth Benchmarks, and Orderly public API are free public endpoints).

# Optional: serve port (default 7011)
PORT=7011

# Optional: path to a Starchild CoinGlass skill dir — enables the
# "any exchange + symbol" fetch path in the asset picker. Without it,
# Hyperliquid + Pyth sources still work.
COINGLASS_SKILL_DIR=/path/to/skills/coinglass

# Optional: Orderly public API base (default https://api.orderly.org)
ORDERLY_BASE=https://api.orderly.org
